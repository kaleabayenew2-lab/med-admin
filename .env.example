# SMS Provider Configuration
# Enable/disable providers (true/false)
REACT_APP_ENABLE_FROMESSAGE=true
REACT_APP_ENABLE_TWILIO=true
REACT_APP_ENABLE_AFRICASTALKING=true
REACT_APP_ENABLE_MESSAGEBIRD=true

# AfroMessage Configuration (Primary SMS Provider for Ethiopia)
REACT_APP_FROMESSAGE_TOKEN=your_fromessage_bearer_token_here
REACT_APP_FROMESSAGE_IDENTIFIER=your_identifier_id_here
REACT_APP_FROMESSAGE_SENDER=FindMe

# Twilio Configuration
REACT_APP_TWILIO_API_KEY=your_twilio_api_key_here
REACT_APP_TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
REACT_APP_TWILIO_FROM_NUMBER=+1234567890

# Africa's Talking Configuration
REACT_APP_AFRICASTALKING_API_KEY=your_africastalking_api_key_here
REACT_APP_AFRICASTALKING_USERNAME=your_africastalking_username_here
REACT_APP_AFRICASTALKING_FROM_NUMBER=FindMe

# MessageBird Configuration
REACT_APP_MESSAGEBIRD_API_KEY=your_messagebird_api_key_here
REACT_APP_MESSAGEBIRD_ORIGINATOR=FindMe

# Email Provider Configuration
# Enable/disable providers (true/false)
REACT_APP_ENABLE_SENDGRID=true
REACT_APP_ENABLE_MAILGUN=true
REACT_APP_ENABLE_SES=true
REACT_APP_ENABLE_NODEMAILER=true

# SendGrid Configuration
REACT_APP_SENDGRID_API_KEY=your_sendgrid_api_key_here
REACT_APP_SENDGRID_FROM_EMAIL=noreply@findme.com

# Mailgun Configuration
REACT_APP_MAILGUN_API_KEY=your_mailgun_api_key_here
REACT_APP_MAILGUN_DOMAIN=your_domain.mailgun.com
REACT_APP_MAILGUN_FROM_EMAIL=noreply@findme.com

# AWS SES Configuration
REACT_APP_AWS_REGION=us-east-1
REACT_APP_AWS_ACCESS_KEY_ID=your_aws_access_key_here
REACT_APP_AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here
REACT_APP_SES_FROM_EMAIL=noreply@findme.com

# SMTP Configuration (for Nodemailer)
REACT_APP_SMTP_HOST=smtp.gmail.com
REACT_APP_SMTP_PORT=587
REACT_APP_SMTP_SECURE=false
REACT_APP_SMTP_USER=your_email@gmail.com
REACT_APP_SMTP_PASS=your_app_password_here
REACT_APP_SMTP_FROM_EMAIL=noreply@findme.com

# OTP Configuration
REACT_APP_OTP_LENGTH=6
REACT_APP_OTP_EXPIRY_MINUTES=10
REACT_APP_MAX_OTP_ATTEMPTS=3
REACT_APP_OTP_RESEND_DELAY_SECONDS=60

# Application Configuration
REACT_APP_API_BASE_URL=https://med-backend-0lw3.onrender.com/api
REACT_APP_ENVIRONMENT=development
