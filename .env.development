# .env.development

# API base URL for development environment
VITE_API_BASE=http://localhost:5000
REACT_APP_API_BASE_URL=http://localhost:5000/api

# Enable React strict mode
REACT_APP_STRICT_MODE=true

# Feature flags
REACT_APP_FEATURE_X_ENABLED=false

# Analytics key (development)
REACT_APP_ANALYTICS_KEY=dev-analytics-key

# Other environment-specific variables can be added below
